# Google OAuth2 app credentials for the Work OS Google Calendar plugin.
#
# These are APP-LEVEL credentials — the same for every user of this CLI.
# They come from the Google Cloud Console where you registered "Work OS" as an app.
#
# Steps to get these:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or select an existing one)
#   3. Enable: Google Calendar API, Google Tasks API
#   4. Go to APIs & Services > Credentials
#   5. Create OAuth 2.0 Client ID (Application type: Desktop app, Name: Work OS CLI)
#   6. Copy the client ID and client secret below
#
# To build with these embedded:
#   Create .cargo/config.toml with:
#
#   [env]
#   GOOGLE_CLIENT_ID = "your-client-id.apps.googleusercontent.com"
#   GOOGLE_CLIENT_SECRET = "GOCSPX-your-client-secret"
#
#   Then just: cargo run or cargo build --release
#
# Each end user then runs `work-os auth google_calendar` to get their own
# access token. Their token is stored in ~/.work-os/config.toml

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
